#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────
# bin/setup_dev — Inicialização do ambiente Rails 8
# Bitwarden: login manual e isolado no shell do usuário.
# Nenhuma chave é passada para os containers.
# ─────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

ok()   { echo -e "${GREEN}✓${RESET} $*"; }
info() { echo -e "${CYAN}→${RESET} $*"; }
warn() { echo -e "${YELLOW}!${RESET} $*"; }
fail() { echo -e "${RED}✗${RESET} $*"; exit 1; }

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "${CYAN}  Rails 8 Dev Environment — setup_dev         ${RESET}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo ""

# ── 1. Pré-requisitos ─────────────────────────

info "Verificando pré-requisitos..."

# Aceita docker ou podman (alguns ambientes como Fedora/RHEL usam podman como alias)
if command -v docker >/dev/null 2>&1; then
  DOCKER_CMD="docker"
elif command -v podman >/dev/null 2>&1; then
  DOCKER_CMD="podman"
  warn "docker não encontrado, usando podman como substituto"
else
  fail "Nem docker nem podman encontrados. Instale o Docker Engine."
fi

command -v bw >/dev/null 2>&1 || warn "Bitwarden CLI (bw) não encontrado. Para instalar: npm install -g @bitwarden/cli"
command -v mise     >/dev/null 2>&1 || {
  # mise pode estar no path do usuário mas não no sudo path
  export PATH="$HOME/.local/share/mise/bin:$HOME/.local/bin:$PATH"
  command -v mise >/dev/null 2>&1 || warn "mise não encontrado no PATH. Ruby/Node podem não estar disponíveis."
}

ok "Pré-requisitos OK"
echo ""

# ── 2. Bitwarden — apenas valida sessão ───────

info "Verificando sessão do Bitwarden..."

BW_LOGGED_IN=false

if ! command -v bw >/dev/null 2>&1; then
  warn "bw não instalado — etapa ignorada"
elif bw status 2>/dev/null | grep -q '"status":"unlocked"'; then
  ok "Bitwarden: sessão ativa e desbloqueada"
  BW_LOGGED_IN=true
elif bw status 2>/dev/null | grep -q '"status":"locked"'; then
  warn "Bitwarden está bloqueado. Para desbloquear:"
  echo "      export BW_SESSION=\$(bw unlock --raw)"
  echo "      Em seguida, execute novamente: bin/setup_dev"
else
  warn "Bitwarden: não autenticado."
  echo "      Para fazer login (interativo, só no seu shell):"
  echo "      bw login"
  echo "      export BW_SESSION=\$(bw unlock --raw)"
  echo "      Em seguida, execute novamente: bin/setup_dev"
fi

# Não bloqueia o setup — containers sobem mesmo sem BW.
# Você precisará do BW apenas para injetar segredos manualmente.
echo ""

# ── 3. Sobe os containers ─────────────────────

COMPOSE_FILE="$(cd "$(dirname "$0")/.." && pwd)/docker-compose.yml"

if [[ ! -f "$COMPOSE_FILE" ]]; then
  fail "docker-compose.yml não encontrado em: $COMPOSE_FILE"
fi

info "Subindo containers (docker compose up -d)..."
$DOCKER_CMD compose -f "$COMPOSE_FILE" up -d --remove-orphans
ok "Containers iniciados"
echo ""

# ── 4. Aguarda PostgreSQL ─────────────────────

info "Aguardando PostgreSQL ficar pronto..."
RETRIES=20
until $DOCKER_CMD compose -f "$COMPOSE_FILE" exec -T db pg_isready -U postgres >/dev/null 2>&1; do
  RETRIES=$((RETRIES - 1))
  if [[ $RETRIES -eq 0 ]]; then
    fail "PostgreSQL não respondeu após 20 tentativas. Verifique: docker compose logs db"
  fi
  sleep 1
done
ok "PostgreSQL pronto"
echo ""

# ── 5. Aguarda Redis ──────────────────────────

info "Aguardando Redis ficar pronto..."
RETRIES=20
until $DOCKER_CMD compose -f "$COMPOSE_FILE" exec -T redis redis-cli ping 2>/dev/null | grep -q "PONG"; do
  RETRIES=$((RETRIES - 1))
  if [[ $RETRIES -eq 0 ]]; then
    fail "Redis não respondeu após 20 tentativas. Verifique: docker compose logs redis"
  fi
  sleep 1
done
ok "Redis pronto"
echo ""

# ── 6. Status final ───────────────────────────

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "${GREEN}  Ambiente pronto!${RESET}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo ""
echo "  Serviços disponíveis:"
echo "  • Rails app    → http://localhost:3000"
echo "  • PostgreSQL   → localhost:5432"
echo "  • Redis        → localhost:6379"
echo "  • Mailcatcher  → http://localhost:1080"
echo "  • Adminer      → http://localhost:8080"
echo ""

if [[ "$BW_LOGGED_IN" == "false" ]]; then
  echo -e "  ${YELLOW}Bitwarden não autenticado.${RESET}"
  echo "  Para injetar segredos no seu shell:"
  echo "  bw login && export BW_SESSION=\$(bw unlock --raw)"
  echo ""
fi
